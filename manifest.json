{
  "manifest_version": 3,
  "name": "RAIN",
  "version": "1.0",
  "description": "Right-click Analyst's IOC Navigator is a SOC tool to speed up hunting of IOCs",
  "permissions": ["contextMenus", "tabs", "scripting", "tabGroups", "storage"],
  "host_permissions": ["https://security.microsoft.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "options.html"
}
